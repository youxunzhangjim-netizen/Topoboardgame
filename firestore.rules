rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomId} {
      function signedIn() {
        return request.auth != null;
      }

      function isPlayer(room) {
        return room.players.white == request.auth.uid
          || room.players.black == request.auth.uid;
      }

      function isPrivateJoin() {
        return resource.data.status == "waiting"
          && request.resource.data.status == "playing"
          && request.resource.data.public == resource.data.public
          && request.resource.data.board == resource.data.board
          && request.resource.data.moveNumber == resource.data.moveNumber
          && request.resource.data.turn == resource.data.turn
          && request.resource.data.gameKey == resource.data.gameKey
          && request.resource.data.matchKey == resource.data.matchKey
          && (
            (
              resource.data.players.white == null
              && resource.data.players.black != null
              && request.resource.data.players.white == request.auth.uid
              && request.resource.data.players.black == resource.data.players.black
            )
            || (
              resource.data.players.black == null
              && resource.data.players.white != null
              && request.resource.data.players.black == request.auth.uid
              && request.resource.data.players.white == resource.data.players.white
            )
          );
      }

      function isPublicWaitingJoin() {
        return resource.data.status == "waiting"
          && resource.data.public == true
          && resource.data.players.waiting != null
          && resource.data.players.waiting != request.auth.uid
          && request.resource.data.status == "playing"
          && request.resource.data.public == resource.data.public
          && request.resource.data.board == resource.data.board
          && request.resource.data.moveNumber == resource.data.moveNumber
          && request.resource.data.turn == resource.data.turn
          && request.resource.data.gameKey == resource.data.gameKey
          && request.resource.data.matchKey == resource.data.matchKey
          && request.resource.data.hostUid == resource.data.hostUid
          && request.resource.data.lastMove == resource.data.lastMove
          && request.resource.data.players.waiting == null
          && (
            (
              request.resource.data.players.white == resource.data.players.waiting
              && request.resource.data.players.black == request.auth.uid
            )
            || (
              request.resource.data.players.black == resource.data.players.waiting
              && request.resource.data.players.white == request.auth.uid
            )
          );
      }

      function isPublicWaitingTouch() {
        return resource.data.status == "waiting"
          && resource.data.public == true
          && resource.data.players.waiting == request.auth.uid
          && request.resource.data.status == resource.data.status
          && request.resource.data.public == resource.data.public
          && request.resource.data.players == resource.data.players
          && request.resource.data.board == resource.data.board
          && request.resource.data.moveNumber == resource.data.moveNumber
          && request.resource.data.turn == resource.data.turn
          && request.resource.data.gameKey == resource.data.gameKey
          && request.resource.data.matchKey == resource.data.matchKey
          && request.resource.data.hostUid == resource.data.hostUid
          && request.resource.data.lastMove == resource.data.lastMove;
      }

      function isJoin() {
        return isPrivateJoin() || isPublicWaitingJoin();
      }

      function isLegalClientMove() {
        return resource.data.status == "playing"
          && resource.data.players[resource.data.turn] == request.auth.uid
          && request.resource.data.players == resource.data.players
          && request.resource.data.gameKey == resource.data.gameKey
          && request.resource.data.matchKey == resource.data.matchKey
          && request.resource.data.moveNumber == resource.data.moveNumber + 1
          && (
            request.resource.data.turn == "white"
            || request.resource.data.turn == "black"
          );
      }

      function isLeave() {
        return isPlayer(resource.data)
          && request.resource.data.board == resource.data.board
          && request.resource.data.moveNumber == resource.data.moveNumber
          && request.resource.data.turn == resource.data.turn
          && request.resource.data.public == resource.data.public
          && request.resource.data.gameKey == resource.data.gameKey
          && request.resource.data.matchKey == resource.data.matchKey
          && request.resource.data.status == "finished"
          && (
            (
              resource.data.players.white == request.auth.uid
              && request.resource.data.players.white == null
              && request.resource.data.players.black == resource.data.players.black
            )
            || (
              resource.data.players.black == request.auth.uid
              && request.resource.data.players.black == null
              && request.resource.data.players.white == resource.data.players.white
            )
          );
      }

      function isPublicWaitingLeave() {
        return resource.data.status == "waiting"
          && resource.data.public == true
          && resource.data.players.waiting == request.auth.uid
          && request.resource.data.status == "finished"
          && request.resource.data.board == resource.data.board
          && request.resource.data.moveNumber == resource.data.moveNumber
          && request.resource.data.turn == resource.data.turn
          && request.resource.data.public == resource.data.public
          && request.resource.data.gameKey == resource.data.gameKey
          && request.resource.data.matchKey == resource.data.matchKey
          && request.resource.data.players.waiting == null
          && request.resource.data.players.white == resource.data.players.white
          && request.resource.data.players.black == resource.data.players.black;
      }

      allow read: if signedIn();

      allow create: if signedIn()
        && (
          (
            request.resource.data.public == true
            && request.resource.data.players.waiting == request.auth.uid
            && request.resource.data.players.white == null
            && request.resource.data.players.black == null
          )
          || (
            request.resource.data.players.white == request.auth.uid
            && request.resource.data.players.black == null
          )
          || (
            request.resource.data.players.black == request.auth.uid
            && request.resource.data.players.white == null
          )
        )
        && request.resource.data.status == "waiting"
        && request.resource.data.public is bool
        && request.resource.data.gameKey is string
        && request.resource.data.matchKey is string
        && request.resource.data.board is string
        && (
          request.resource.data.turn == "white"
          || request.resource.data.turn == "black"
        )
        && request.resource.data.moveNumber == 0;

      allow update: if signedIn()
        && (isJoin() || isPublicWaitingTouch() || isLegalClientMove() || isLeave() || isPublicWaitingLeave());

      allow delete: if false;

      match /messages/{messageId} {
        function roomData() {
          return get(/databases/$(database)/documents/rooms/$(roomId)).data;
        }

        function isRoomPlayer() {
          return request.auth != null
            && (
              roomData().players.white == request.auth.uid
              || roomData().players.black == request.auth.uid
            );
        }

        allow read: if isRoomPlayer();
        allow create: if isRoomPlayer()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 240;
        allow update, delete: if false;
      }
    }
  }
}
