{
  "name": "topological-boardgame",
  "private": true,
  "type": "module",
  "workspaces": [
    "2D/2dchess",
    "2D/2dgo",
    "2D/2dreversi",
    "3D/3dchess",
    "3D/3dgo",
    "3D/3dreversi",
    "4D/4dgo",
    "4D/4dreversi",
    "algebraic"
  ],
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5172",
    "local": "vite --host 127.0.0.1 --port 5172 --open",
    "build": "node tools/build-website.mjs",
    "build:2d": "npm run build --workspace 2dchess",
    "build:3d": "npm run build --workspace 3dchess",
    "build:3dspace": "npm run build --workspace 3dchess",
    "dev:2d": "npm run dev --workspace 2dchess",
    "dev:3d": "npm run dev --workspace 3dchess",
    "dev:3dspace": "npm run dev --workspace 3dchess",
    "build:2dgo": "npm run build --workspace 2dgo",
    "build:3dgo": "npm run build --workspace 3dgo",
    "dev:2dgo": "npm run dev --workspace 2dgo",
    "dev:3dgo": "npm run dev --workspace 3dgo",
    "build:2dreversi": "npm run build --workspace 2dreversi",
    "build:3dreversi": "npm run build --workspace 3dreversi",
    "dev:2dreversi": "npm run dev --workspace 2dreversi",
    "dev:3dreversi": "npm run dev --workspace 3dreversi",
    "build:4dgo": "npm run build --workspace 4dgo",
    "dev:4dgo": "npm run dev --workspace 4dgo",
    "build:4dreversi": "npm run build --workspace 4dreversi",
    "dev:4dreversi": "npm run dev --workspace 4dreversi",
    "build:algebraic": "npm run build --workspace algebraic-games",
    "dev:algebraic": "npm run dev --workspace algebraic-games",
    "verify:probability": "node tools/verify-probability-engine.mjs",
    "verify:floquet": "node tools/verify-floquet-engine.mjs",
    "verify:defaults": "node tools/verify-default-board-sizes.mjs",
    "verify:braid-memory": "node tools/verify-braid-memory.mjs",
    "verify:physical-problems": "node tools/verify-physical-problems.mjs",
    "verify:local-robots": "node tools/verify-local-robot-coverage.mjs",
    "local:app": "node tools/local-app-launcher.mjs",
    "desktop:dev": "node tools/desktop-dev.mjs",
    "research:selfplay": "node research/selfplay.mjs",
    "research:aggregate": "node research/aggregate-stats.mjs",
    "research:smoke": "node research/selfplay-smoke.mjs",
    "verify:research": "node research/selfplay-smoke.mjs",
    "research:batch": "node research/selfplay-batch.mjs",
    "ml:train-linear": "node research/ml/train-linear.mjs",
    "ml:evaluate-linear": "node research/ml/evaluate-linear.mjs",
    "ml:export-dataset": "node research/ml/export-dataset.mjs",
    "verify:ml": "node research/ml/ml-smoke.mjs",
    "ml:train-all": "node research/ml/train-all-linear.mjs",
    "desktop:dir": "npm run build && electron-builder --dir",
    "desktop:package": "npm run build && electron-builder",
    "desktop:win": "npm run build && electron-builder --win",
    "desktop:mac": "npm run build && electron-builder --mac",
    "desktop:linux": "npm run build && electron-builder --linux",
    "preupload:files": "node scripts/preupload-check.mjs",
    "models:promote": "powershell -ExecutionPolicy Bypass -File scripts/Promote-TrainedModels.ps1",
    "preupload:check": "powershell -ExecutionPolicy Bypass -File scripts/Preupload-Check.ps1",
    "verify:life": "node tools/verify-life-worlds.mjs",
    "steam:check-info": "node scripts/check-steam-upload-info.mjs",
    "steam:prepare-vdf": "node scripts/prepare-steam-vdf.mjs"
  },
  "dependencies": {
    "firebase": "^12.14.0",
    "peerjs": "^1.5.5",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "vite": "^8.0.16",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12"
  },
  "license": "SEE LICENSE IN LICENSE.md",
  "main": "local-app/electron/main.cjs",
  "buildConfigNote": "Electron-builder config is under the top-level build field.",
  "build": {
    "appId": "com.topoboardgame.app",
    "productName": "Topoboardgame",
    "copyright": "Copyright © 2026 Youxun Zhang / Topoboardgame",
    "directories": {
      "output": "release",
      "buildResources": "local-app/build-resources"
    },
    "files": [
      "dist/**/*",
      "local-app/electron/**/*",
      "local-app/build-resources/**/*",
      "package.json",
      "LICENSE.md",
      "COMMERCIAL_LICENSE_REQUEST.md",
      "THIRD_PARTY_NOTICES.md",
      "STEAM_RELEASE_CHECKLIST.md"
    ],
    "extraMetadata": {
      "main": "local-app/electron/main.cjs"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "local-app/build-resources/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.games",
      "icon": "local-app/build-resources/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "Game",
      "icon": "local-app/build-resources/icon.png"
    },
    "icon": "local-app/build-resources/icon.png"
  },
  "version": "0.1.0",
  "productName": "Topoboardgame",
  "description": "A playable topological board-game and life-simulation platform with local robots, research tools, and experimental strategy worlds.",
  "author": {
    "name": "You-Xun Zhang",
    "email": "youxunzhangjim@gmail.com"
  },
  "homepage": "https://github.com/youxunzhangjim-netizen/Topoboardgame"
}
