{
  "name": "topological-boardgame",
  "private": true,
  "type": "module",
  "workspaces": [
    "2D/2dchess",
    "2D/2dgo",
    "2D/2dreversi",
    "3D/3dchess",
    "3D/3dgo",
    "3D/3dreversi",
    "4D/4dgo",
    "4D/4dreversi",
    "algebraic"
  ],
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5172",
    "local": "vite --host 127.0.0.1 --port 5172 --open",
    "dev:web": "vite --mode web-lite --host 0.0.0.0 --port 5172",
    "dev:steam": "vite --mode steam-stable --host 0.0.0.0 --port 5173",
    "dev:research": "vite --mode research-dev --host 0.0.0.0 --port 5174",
    "build": "node tools/build-website.mjs",
    "build:web": "node tools/build-website.mjs --edition web-lite --outDir dist-web && node scripts/write-version.mjs web-lite dist-web && node scripts/verify-web-dist.mjs dist-web",
    "build:steam": "node tools/build-website.mjs --edition steam-stable --outDir dist-steam && node scripts/write-version.mjs steam-stable dist-steam",
    "build:research": "node tools/build-website.mjs --edition research-dev --outDir dist-research && node scripts/write-version.mjs research-dev dist-research",
    "verify:web-dist": "node scripts/verify-web-dist.mjs dist-web",
    "build:2d": "npm run build --workspace 2dchess",
    "build:3d": "npm run build --workspace 3dchess",
    "build:3dspace": "npm run build --workspace 3dchess",
    "dev:2d": "npm run dev --workspace 2dchess",
    "dev:3d": "npm run dev --workspace 3dchess",
    "dev:3dspace": "npm run dev --workspace 3dchess",
    "build:2dgo": "npm run build --workspace 2dgo",
    "build:3dgo": "npm run build --workspace 3dgo",
    "dev:2dgo": "npm run dev --workspace 2dgo",
    "dev:3dgo": "npm run dev --workspace 3dgo",
    "build:2dreversi": "npm run build --workspace 2dreversi",
    "build:3dreversi": "npm run build --workspace 3dreversi",
    "dev:2dreversi": "npm run dev --workspace 2dreversi",
    "dev:3dreversi": "npm run dev --workspace 3dreversi",
    "build:4dgo": "npm run build --workspace 4dgo",
    "dev:4dgo": "npm run dev --workspace 4dgo",
    "build:4dreversi": "npm run build --workspace 4dreversi",
    "dev:4dreversi": "npm run dev --workspace 4dreversi",
    "build:algebraic": "npm run build --workspace algebraic-games",
    "dev:algebraic": "npm run dev --workspace algebraic-games",
    "verify:probability": "node tools/verify-probability-engine.mjs",
    "verify:floquet": "node tools/verify-floquet-engine.mjs",
    "verify:defaults": "node tools/verify-default-board-sizes.mjs",
    "verify:braid-memory": "node tools/verify-braid-memory.mjs",
    "verify:physical-problems": "node tools/verify-physical-problems.mjs",
    "verify:local-robots": "node tools/verify-local-robot-coverage.mjs",
    "local:app": "node tools/local-app-launcher.mjs",
    "desktop:dev": "node tools/desktop-dev.mjs",
    "research:selfplay": "node research/selfplay.mjs",
    "research:aggregate": "node research/aggregate-stats.mjs",
    "research:smoke": "node research/selfplay-smoke.mjs",
    "verify:research": "node research/selfplay-smoke.mjs",
    "research:batch": "node research/selfplay-batch.mjs",
    "train:selfplay": "node ai/cli/train-selfplay.mjs",
    "train:variant": "node ai/cli/train-variant.mjs",
    "eval:robots": "node ai/cli/eval-robots.mjs",
    "export:model": "node ai/cli/export-model.mjs",
    "ml:train-linear": "node research/ml/train-linear.mjs",
    "ml:evaluate-linear": "node research/ml/evaluate-linear.mjs",
    "ml:export-dataset": "node research/ml/export-dataset.mjs",
    "verify:ml": "node research/ml/ml-smoke.mjs",
    "ml:train-all": "node research/ml/train-all-linear.mjs",
    "ai:ingest:chess": "node --experimental-strip-types scripts/ai/ingest/ingestChessPgn.ts",
    "ai:book:chess": "node --experimental-strip-types scripts/ai/ingest/buildChessOpeningBook.ts",
    "ai:stockfish": "node --experimental-strip-types scripts/ai/ingest/analyzeChessWithStockfish.ts",
    "ai:syzygy": "node --experimental-strip-types scripts/ai/ingest/configureChessSyzygy.ts",
    "ai:ingest:go": "node --experimental-strip-types scripts/ai/ingest/ingestGoSgf.ts",
    "ai:book:go": "node --experimental-strip-types scripts/ai/ingest/buildGoJosekiFusekiBook.ts",
    "ai:katago": "node --experimental-strip-types scripts/ai/ingest/analyzeGoWithKataGo.ts",
    "ai:ingest:reversi": "node --experimental-strip-types scripts/ai/ingest/ingestReversiWthor.ts",
    "ai:book:reversi": "node --experimental-strip-types scripts/ai/ingest/buildReversiOpeningBook.ts",
    "ai:edax": "node --experimental-strip-types scripts/ai/ingest/analyzeReversiWithEdax.ts",
    "ai:book:jump": "node --experimental-strip-types scripts/ai/ingest/buildChineseCheckersStrategyRules.ts",
    "ai:knowledge:build": "node --experimental-strip-types scripts/ai/ingest/buildStrategyKnowledge.ts",
    "ai:knowledge:build-all": "node --experimental-strip-types scripts/ai/ingest/buildAllStrategyKnowledge.ts",
    "ai:selfplay:chess": "node --experimental-strip-types scripts/ai/train/selfPlayChess.ts",
    "ai:selfplay:go": "node --experimental-strip-types scripts/ai/train/selfPlayGo.ts",
    "ai:selfplay:reversi": "node --experimental-strip-types scripts/ai/train/selfPlayReversi.ts",
    "ai:selfplay:jump": "node --experimental-strip-types scripts/ai/train/selfPlayChineseCheckers.ts",
    "ai:evaluate": "node --experimental-strip-types scripts/ai/train/evaluateBots.ts",
    "desktop:dir": "npm run build && electron-builder --dir --config.electronDist=node_modules/electron/dist",
    "desktop:package": "npm run build && electron-builder",
    "desktop:win": "npm run build && electron-builder --win",
    "desktop:mac": "npm run build && electron-builder --mac",
    "desktop:linux": "npm run build && electron-builder --linux",
    "preupload:files": "node scripts/preupload-check.mjs",
    "models:promote": "powershell -ExecutionPolicy Bypass -File scripts/Promote-TrainedModels.ps1",
    "preupload:check": "powershell -ExecutionPolicy Bypass -File scripts/Preupload-Check.ps1",
    "verify:life": "node tools/verify-life-worlds.mjs",
    "verify:board-spec-infra": "node verification/verify-board-spec-infra.mjs",
    "verify:safe-labs-infra": "node verification/verify-safe-labs-infra.mjs",
    "verify:vertex-go-boards": "node verification/verify-vertex-go-boards.mjs",
    "verify:go-scoring": "node verification/verify-go-scoring.mjs",
    "verify:board-stability": "node verification/verify-board-stability-layer.mjs",
    "verify:lab-safety": "node verification/verify-safe-lab-runner.mjs",
    "verify:klein-surface": "node verification/verify-klein-surface.mjs",
    "verify:desktop-save": "node verification/verify-desktop-save.mjs",
    "verify:electron-save": "node verification/verify-electron-save-bridge.mjs",
    "verify:edition-env": "node verification/verify-edition-env.mjs",
    "verify:online-crossplay": "node verification/verify-online-crossplay-config.mjs",
    "verify:jump-surfaces": "node verification/verify-jump-surfaces.mjs",
    "verify:robot-legality": "node verification/verify-robot-move-legality.mjs",
    "verify:hex-robot-strategy": "node verification/verify-hex-robot-strategy.mjs",
    "verify:jump-ui": "node verification/verify-jump-ui.mjs",
    "verify:steam-safe": "node verification/verify-steam-safe-build.mjs",
    "clean:release": "node scripts/package-release.mjs clean",
    "pack:web-lite": "npm run build && node scripts/package-release.mjs web-lite",
    "pack:steam-lite": "npm run build && node scripts/package-release.mjs steam-lite",
    "pack:research-pack": "node scripts/package-release.mjs research-pack",
    "steam:check-info": "node scripts/check-steam-upload-info.mjs",
    "steam:prepare-vdf": "node scripts/prepare-steam-vdf.mjs"
  },
  "dependencies": {
    "firebase": "^12.14.0",
    "peerjs": "^1.5.5",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "vite": "^8.0.16",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12"
  },
  "license": "SEE LICENSE IN LICENSE.md",
  "main": "local-app/electron/main.cjs",
  "buildConfigNote": "Electron-builder config is under the top-level build field.",
  "build": {
    "appId": "com.topoboardgame.app",
    "productName": "Topoboardgame",
    "copyright": "Copyright © 2026 Youxun Zhang / Topoboardgame",
    "directories": {
      "output": "release",
      "buildResources": "local-app/build-resources"
    },
    "files": [
      "dist/**/*",
      "local-app/electron/**/*",
      "local-app/build-resources/**/*",
      "package.json",
      "LICENSE.md",
      "COMMERCIAL_LICENSE_REQUEST.md",
      "THIRD_PARTY_NOTICES.md",
      "STEAM_RELEASE_CHECKLIST.md"
    ],
    "extraMetadata": {
      "main": "local-app/electron/main.cjs"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "local-app/build-resources/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.games",
      "icon": "local-app/build-resources/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "Game",
      "icon": "local-app/build-resources/icon.png"
    },
    "icon": "local-app/build-resources/icon.png"
  },
  "version": "0.1.0",
  "productName": "Topoboardgame",
  "description": "A playable topological board-game and life-simulation platform with local robots, research tools, and experimental strategy worlds.",
  "author": {
    "name": "You-Xun Zhang",
    "email": "youxunzhangjim@gmail.com"
  },
  "homepage": "https://github.com/youxunzhangjim-netizen/Topoboardgame"
}
